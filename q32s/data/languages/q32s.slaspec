# Sleigh specification file for q32s Processor
# Instruction definitions from here https://kagaimiq.github.io/jielie/cpu/q32s.html

define endian=little;
define alignment=2;

define space ram     type=ram_space      size=4  default;

define space register type=register_space size=4;

define token opbyte (16)
	op0 = (0, 0)
	op1 = (1, 1)
	op2 = (2, 2)
	op3 = (3, 3)
	op4 = (4, 4)
	op5 = (5, 5)
	op6 = (6, 6)
	op7 = (7, 7)
	op8 = (8, 8)
	op9 = (9, 9)
	op10 = (10, 10)
	op11 = (11, 11)
	op12 = (12, 12)
	op13 = (13, 13)
	op14 = (14, 14)
	op15 = (15, 15)
	
	op0_1 = (0, 1)
	op0_4 = (0, 4)
	op0_3 = (0, 3)
	op4_6 = (4, 6)
	op7_11 = (7, 11)
	op8_11 = (8, 11)
	
	op0_15 = (0, 15)
	op1_15 = (1, 15)
	op2_15 = (2, 15)
	op3_15 = (3, 15)
	op4_15 = (4, 15)
	op5_15 = (5, 15)
	op6_15 = (6, 15)
	op7_15 = (7, 15)
	op8_15 = (8, 15)
	op9_15 = (9, 15)
	op11_15 = (11, 15)
	op12_15 = (12, 15)
	
	imm0 = (0, 0)
	imm3 = (3, 3)
	
	srx0_3 = (0,3)
	rx0_3 = (0,3)
	rx0_2 = (0,2)
	rx9_11 = (9,11)
	rx12_15 = (12,15)
	
	rz9_11 = (9, 11)
	
	
	
	ry6_8 = (6, 8)
	ry3_5 = (3, 5)
	ry4_7 = (4, 7)
	ry8_11 = (8, 11)
	ry9_11 = (9, 11)
	ry12_15 = (12, 15)
	
	
	rz6_8 = (6, 8)
	rz4_7 = (4, 7)
	rz8_11 = (8, 11)
	
	
	
	sry8_11 = (8, 11)
	
	imm0_8s = (0, 8) signed
	imm0_5s = (0, 5) signed
	imm0_5 = (0, 5)
	imm0_4 = (0, 4)
	imm0_6 = (0, 6)
	imm0_7 = (0, 7)
	imm3_10 = (3, 10)
	imm4_5 = (4, 5)
	imm4_7 = (4, 7)
	imm4_8 = (4, 8)
	imm6_10 = (6, 10)
	imm4_11 = (4, 11)
	imm4_11s = (4, 11) signed
	imm7_11 = (7, 11)
	imm0_10s = (0, 10) signed
	imm1_10s = (1, 10) signed
	imm1_8s = (1, 8) signed
	
	imm0_11 = (0, 11)
	imm0_11s = (0, 11) signed
	
	imm0_12s = (0, 12) signed
	
	imm0_15s = (0, 15) signed
	imm0_15 = (0, 15)
	imm0_15_dup = (0, 15)
	
	
	imm0_2 = (0, 2)
;

define register offset=0x00 size=4 [ 
	r0 r1 r2 r3
	r4 r5 r6 r7
	r8 r9 r10 r11
	r12 r13 r14 r15
	
	reti   # sr0
	rete
	retx
	rets
	sr4
	psr
	cnum
	sr7
	sr8
	sr9
	sr10
	icfg
	usp
	ssp
	sp
	pc     # sr15
];

define register offset=0x100 size=64 [
    testctx
];

define context testctx
    stage         = (  0, 8) noflow
    
    #TODO: put in order
    save_reti = (9, 9) noflow
    save_rete = (10, 10) noflow
    save_retx = (11, 11) noflow
    save_rets = (12, 12) noflow
    save_sr4 = (13, 13) noflow
    save_psr = (14, 14) noflow
    
    save_r0 = (15, 15) noflow
    save_r1 = (16, 16) noflow
    save_r2 = (17, 17) noflow
    save_r3 = (18, 18) noflow
    save_r4 = (19, 19) noflow
    save_r5 = (20, 20) noflow
    save_r6 = (21, 21) noflow
    save_r7 = (22, 22) noflow
    save_r8 = (23, 23) noflow
    save_r9 = (24, 24) noflow
    save_r10 = (25, 25) noflow
    save_r11 = (26, 26) noflow
    save_r12 = (27, 27) noflow
    save_r13 = (28, 28) noflow
    save_r14 = (29, 29) noflow
    save_r15 = (30, 30) noflow
    
    save_cnum = (31, 31) noflow
    save_sr7 = (32, 32) noflow
    save_sr8 = (33, 33) noflow
    save_sr9 = (34, 34) noflow
    save_sr10 = (35, 35) noflow
    save_icfg = (36, 36) noflow
    save_usp = (37, 37) noflow
    save_ssp = (38, 38) noflow
    save_sp = (39, 39) noflow
    save_pc = (40, 40) noflow
;


attach variables [rx0_3 rx12_15 ry4_7 ry8_11 rz4_7 ry12_15 rz8_11] [
	r0 r1 r2 r3
	r4 r5 r6 r7
	r8 r9 r10 r11
	r12 r13 r14 r15
];

attach variables [rx0_2 ry6_8 ry3_5 ry9_11 rz6_8 rx9_11 rz9_11] [
	r0 r1 r2 r3
	r4 r5 r6 r7
];

attach variables [sry8_11 srx0_3] [
	reti
	rete
	retx
	rets
	sr4
	psr
	cnum
	sr7
	sr8
	sr9
	sr10
	icfg
	usp
	ssp
	sp

	# TODO: assign = goto
	pc
];

#TODO: actually compute flags
define bitrange V=psr[0,1] # Overflow
				C=psr[1,1] # Carry
				Z=psr[2,1] # Zero
				N=psr[3,1] # Negative
;

#TODO: _stub
#TODO: flag setting?

define pcodeop _stub;

macro push(v) {
	sp = sp - 4;
	*[ram]:4 sp = v;
}

macro pop(o) {
	o = *[ram]:4 sp;
	sp = sp + 4;
}

macro rotl32(out, a, b) {
	local d:4 = b;
	local n:4 = a;
	local out1:4 = (n << d) | ( n >> (32 - d));
	out = out1;
}


define pcodeop nop;

:nop is op1_15=0b000000000000000 {
	nop();
}

define pcodeop idle;

:idle is op1_15=0b000000000000001 {
	idle();
}

define pcodeop bkpt;

:bkpt is op1_15=0b000000000000010 {
	bkpt();
}

define pcodeop hbkpt;

:hbkpt is op1_15=0b000000000000011 {
	hbkpt();
}

define pcodeop csync;

:csync is op1_15=0b000000000000100 {
	csync();
}

define pcodeop ssync;

:ssync is op1_15=0b000000000000101 {
	ssync();
}

define pcodeop syscall;

:syscall is op1_15=0b000000000000110 {
	syscall();
}

define pcodeop lockclr;

:lockclr is op2_15=0b00000000000100 {
	lockclr();
}

define pcodeop lockset;

:lockset is op2_15=0b00000000000101 {
	lockset();
}

define pcodeop cli;

:cli is op2_15=0b00000000000110 {
	cli();
}

define pcodeop sti;

:sti is op2_15=0b00000000000111 {
	sti();
}


# Return to subroutine
:rts is op1_15=0b000000000010000 {
	return [rets];
}

:rti is op1_15=0b000000000010001 {
    return [reti];
}

:rtx is op1_15=0b000000000010010 {
	return [retx];
}

:rte is op1_15=0b000000000010011 {
   return [rete];
}

define pcodeop swi;

:swi imm0_2 is op3_15=0b0000000000101 & imm0_2 {
	swi(imm0_2:1);
}


:pc = [sp++] is op2_15=0b00000000001100 & sp {
	local tmp:4 = *[ram]:4 sp;
	sp = sp + 4;
	return [tmp];
}

:[--sp]=rets is op2_15=0b00000000001101 & sp & rets {
	sp = sp - 4;
	*[ram]:4 sp = rets;
}

:cc=0 is op1_15=0b000000000011100 {
	C = 0;
}
:cc=1 is op1_15=0b000000000011101 {
	C = 1;
}

:sp = usp is op0_15=0b0000000000111100 & usp {
	sp = usp;
}

:sp = ssp is op0_15=0b0000000000111101 & ssp {
	sp = ssp;
}

:usp = sp is op0_15=0b0000000000111110 & sp {
	usp = sp;
}

:ssp = sp is op0_15=0b0000000000111111 & sp {
	ssp = sp;
}

:testset "b"[rx0_3] is op5_15=0b00000000010 & rx0_3 {
    # Assuming this works like 68k
    local tmp:1 = *[ram]:1 rx0_3;
    Z = tmp == 0;
    N = tmp s< 0;
	*[ram]:1 rx0_3 = tmp | (1 << 7);
}


:cli rx0_3 is op4_15=0b000000000110 & rx0_3 {
	cli(rx0_3);
}

:sti rx0_3 is op4_15=0b000000000111 & rx0_3 {
	sti(rx0_3);
}

:call rx0_3 is op4_15=0b000000001000 & rx0_3 {
	rets = inst_next;
	call [rx0_3];
}

:goto rx0_3 is op4_15=0b000000001001 & rx0_3 {
	goto [rx0_3];
}

:tbb [rx0_3] is op4_15=0b000000001010 & rx0_3 {
	local tmp:4 = inst_next + rx0_3;
	local dest:4 = inst_next + (zext(*[ram]:1 tmp) << 1);
	goto [dest];
}

:tbh [rx0_3] is op4_15=0b000000001011 & rx0_3 {
	local tmp:4 = inst_next + rx0_3;
	local dest:4 = inst_next + zext(*[ram]:2 tmp) << 1;
	goto [dest];
}

define pcodeop pfetch;

:pfetch [rx0_3] is op4_15=0b000000001100 & rx0_3 {
	pfetch(rx0_3);
}

define pcodeop iflush;

:iflush [rx0_3] is op4_15=0b000000001101 & rx0_3 {
	iflush(rx0_3);
}

define pcodeop flush;

:flush [rx0_3] is op4_15=0b000000001110 & rx0_3 {
	flush(rx0_3);
}

define pcodeop flushinv;

:flushinv [rx0_3] is op4_15=0b000000001111 & rx0_3 {
	flushinv(rx0_3);
}

# Pop without rets

:{r3-r0} = [sp++] is op6_15=0b0000000100 & op0_4=0b00000 & sp & r3 & r0 {
	pop(r3);
	pop(r2);
	pop(r1);
	pop(r0);
}

:{r3-r1} = [sp++] is op6_15=0b0000000100 & op0_4=0b00001 & sp & r3 & r1 {
	pop(r3);
	pop(r2);
	pop(r1);
}

:{r3, r2} = [sp++] is op6_15=0b0000000100 & op0_4=0b00010 & sp & r3 & r2 {
