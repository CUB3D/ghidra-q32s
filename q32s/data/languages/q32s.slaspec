# Pop with pc

:{"pc", r3-r0} = [sp++] is op0_15=0b0000000101010000 & sp & r3 & r0 {
	pop(r3);
	pop(r2);
	pop(r1);
	pop(r0);
	local tmp:4 = 0;
	pop(tmp);
	return [tmp];
}

:{"pc", r3-r1} = [sp++] is op0_15=0b0000000101010001 & sp & r3 & r1 {
	pop(r3);
