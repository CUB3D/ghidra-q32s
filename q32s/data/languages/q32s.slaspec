		push(reti);
	<noreti>
	if(save_rete:1 == 0) goto <norete>;
		push(rete);
	<norete>
	if(save_retx:1 == 0) goto <noretx>;
		push(retx);
	<noretx>
	if(save_rets:1 == 0) goto <norets>;
		push(rets);
	<norets>
	if(save_sr4:1 == 0) goto <nosr4>;
		push(sr4);
	<nosr4>
	if(save_psr:1 == 0) goto <nopsr>;
		push(psr);
	<nopsr>
}


