# Pop special register list
:"" { srreglist } = [sp++] is op6_15=0b0000000110 & srreglist & sp & save_reti & save_rete & save_retx & save_rets & save_sr4 & save_psr [stage=0;] {
	if(save_psr:1 == 0) goto <nopsr>;
		pop(psr);
	<nopsr>
	if(save_sr4:1 == 0) goto <nosr4>;
		pop(sr4);
	<nosr4>
	if(save_rets:1 == 0) goto <norets>;
		pop(rets);
	<norets>
	if(save_retx:1 == 0) goto <noretx>;
		pop(retx);
	<noretx>
	if(save_rete:1 == 0) goto <norete>;
		pop(rete);
	<norete>
	if(save_reti:1 == 0) goto <noreti>;
		pop(reti);
	<noreti>
}

